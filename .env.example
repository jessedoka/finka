DATABASE_URL=postgresql+asyncpg://finka:finka@localhost:5432/finka_dev
ENVIRONMENT=development
COGNITO_USER_POOL_ID=local
COGNITO_APP_CLIENT_ID=local
AWS_REGION=eu-west-2

# --- Provider credentials: OPTIONAL, SEED-ONLY -------------------------------
# You do NOT need any of these. Add your data sources through the Connections
# page in the app — credentials are stored per-source in the database.
#
# These are read only by `python -m scripts.seed_connections`, a convenience for
# scripted deploys that turns them into connections on first run. Leave blank
# unless you're using that path.

# Trading212 (read-only). Settings -> API (Beta) on your live account.
TRADING_212_KEY=

# Coinbase (read-only). A CDP API key with "View" permission from
# https://portal.cdp.coinbase.com/ -> API keys: a key name/id and a private key.
# Paste a PEM as a single line with \n for newlines.
COINBASE_API_KEY_NAME=
COINBASE_API_PRIVATE_KEY=

# Monzo (read-only). A playground access token + account id from
# https://developers.monzo.com/. NOTE: playground tokens expire after a few
# hours and can't be auto-refreshed — the app surfaces the error when they do.
MONZO_ACCESS_TOKEN=
MONZO_ACCOUNT_ID=
# Projection assumptions seeded onto the Monzo connection (net worth counts pots
# only, not the spendable current account). Growth rate is a fraction (0.02 = 2%/yr).
MONZO_POTS_MONTHLY_CONTRIBUTION=0
MONZO_POTS_GROWTH_RATE=0

# Daily net-worth snapshot scheduler (runs inside the API container).
SNAPSHOT_SCHEDULER_ENABLED=true
SNAPSHOT_TIME=00:30
