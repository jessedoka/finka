DATABASE_URL=postgresql+asyncpg://finka:finka@localhost:5432/finka_dev
ENVIRONMENT=development
COGNITO_USER_POOL_ID=local
COGNITO_APP_CLIENT_ID=local
AWS_REGION=eu-west-2

# Trading212 (read-only). Settings -> API (Beta) on your live account.
TRADING_212_KEY=ExampleString

# Coinbase (read-only). Create a CDP API key with "View" permission at
# https://portal.cdp.coinbase.com/ -> API keys. You get a key name/id and a
# PEM private key. Paste the PEM as a single line with \n for newlines.
COINBASE_API_KEY_NAME=
COINBASE_API_PRIVATE_KEY=

# Monzo (read-only). Grab a playground access token + your account id from
# https://developers.monzo.com/. NOTE: playground tokens expire after a few
# hours and can't be auto-refreshed — paste a fresh one when reads start 401ing.
MONZO_ACCESS_TOKEN=
MONZO_ACCOUNT_ID=
MONZO_USER_ID=

# Daily net-worth snapshot scheduler (runs inside the API container).
SNAPSHOT_SCHEDULER_ENABLED=true
SNAPSHOT_TIME=00:30
